{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // 端末を常にダーク配色にする (背景が暗いので文字色も明るく固定して可読性を確保)
  "app": {
    "appearance": "dark",
    // 通知が来てもサイドバーのタブ順を自動で並び替えない (順序を固定する)
    "reorderOnNotification": false
  },

  // ワークスペースコマンド: コマンドパレット (cmd+shift+p) から "ccremote" を選ぶと
  // 左に ~/z、右側を上下分割 (上: security-ledger / 下: aegis) で 3 つのターミナルが開き、
  // それぞれ自動で claude (+/remote-control) が起動する。
  "commands": [
    {
      "name": "ccremote",
      "description": "左: ~/z で claude (+/remote-control) / 右上: security-ledger / 右下: aegis",
      "keywords": ["ccremote", "cc remote", "claude", "remote", "ledger", "aegis", "3画面", "split"],
      "workspace": {
        "name": "CC remote",
        "cwd": "~",
        "layout": {
          "direction": "horizontal",
          "split": 0.5,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "claude (~/z)",
                    "cwd": "~/z",
                    // 起動と同時に /remote-control を初期プロンプトとして実行
                    "command": "claude --dangerously-skip-permissions \"/remote-control\"",
                    "focus": true
                  }
                ]
              }
            },
            {
              // 右側カラムを上下に分割して 2 つのターミナルを配置する
              "direction": "vertical",
              "split": 0.5,
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "security-ledger",
                        "cwd": "~/github/CureApp/security-ledger",
                        // 起動と同時に /remote-control を初期プロンプトとして実行
                        "command": "claude --dangerously-skip-permissions \"/remote-control\""
                      }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "aegis",
                        "cwd": "~/github/CureApp/aegis",
                        // 起動と同時に /remote-control を初期プロンプトとして実行
                        "command": "claude --dangerously-skip-permissions \"/remote-control\""
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      }
    }
  ],

